{
  "singleQuote": false,
  "printWidth": 120,
  "trailingComma": "es5",
  "endOfLine": "lf",
  "semi": true,
  "tabWidth": 2,
  "overrides": [
    {
      "files": [
        "*.html"
      ],
      "options": {
        "parser": "angular",
        "singleQuote": false
      }
    },
    {
      "files": [
        "*.scss"
      ],
      "options": {
        "parser": "scss"
      }
    },
    {
      "files": [
        "*.ts",
        "*.js"
      ],
      "options": {
        "singleQuote": true
      }
    }
  ]
}
